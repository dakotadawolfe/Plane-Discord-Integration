{
  "name": "@project-desk/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc -p tsconfig.scripts.json",
    "pin-launch": "tsx scripts/pin-launch-message.ts",
    "register-entrypoint": "tsx scripts/register-entrypoint.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "cookie-session": "^2.1.0",
    "discord.js": "^14.22.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6"
  }
}
